{
  "name": "@usemosaicxyz/ts-sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for Mosaic bounty contracts on Base and the Mortar API",
  "keywords": [
    "mosaic",
    "bounty",
    "base",
    "ethereum",
    "usdc",
    "sdk",
    "typescript"
  ],
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/usemosaicxyz/ts-sdk.git"
  },
  "homepage": "https://www.npmjs.com/package/@usemosiac/ts-sdk",
  "bugs": {
    "url": "https://github.com/usemosaicxyz/ts-sdk/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
