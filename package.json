{
  "name": "@usemosaicxyz/ts-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Mosaic bounty contracts on Base and the Mortar API",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usemosaicxyz/ts-sdk.git"
  },
  "homepage": "https://github.com/usemosaicxyz/ts-sdk#readme",
  "bugs": {
    "url": "https://github.com/usemosaicxyz/ts-sdk/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
